{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"types": ["node", "bun"],
		"allowImportingTsExtensions": true
	},
	"include": ["*.ts", "*.d.ts", "../_types/**/*.d.ts"]
}
